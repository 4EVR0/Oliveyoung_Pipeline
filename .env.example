# EC2 프로덕션 환경에서는 IAM Role이 자동으로 AWS 인증을 처리하므로
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY 설정이 필요 없습니다.

AWS_DEFAULT_REGION=ap-northeast-2
S3_BUCKET=oliveyoung-crawl-data
ICEBERG_DATABASE=oliveyoung_db

# =========================
# 로깅
# =========================
# 로그 출력 형식: json (CloudWatch 운영), text (로컬 개발)
LOG_FORMAT=json

# 로그 레벨: DEBUG, INFO, WARNING, ERROR (기본값: INFO)
LOG_LEVEL=INFO
